# Copy to .env and fill in your values (never commit .env)

# ---- Text generation (choose one; Claude is highest quality) ----
# Claude Opus 4.8 — best writing quality (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-8

# Google Gemini — cheaper fallback (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Which provider to use: auto | claude | gemini  (auto prefers Claude)
# TEXT_PROVIDER=auto

# ---- Image generation ----
# Photos: Imagen 4 Ultra (2K). Infographics: HTML template (crisp text).
# IMAGEN_MODEL=imagen-4.0-ultra-generate-001
# IMAGE_SIZE=2K
# Branding shown on infographics:
# BRAND_NAME=iNOTRO Multiservices
# BRAND_TAGLINE=Odoo ERP & AI · Dubai, UAE

# ---- LinkedIn ----
LI_CLIENT_ID=
LI_CLIENT_SECRET=
COMPANY_ID=
